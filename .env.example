# ============================================================
# .env — SECRETS ONLY
# All other settings live in config.py
#
# Copy this file to .env and fill in your values.
# For GitHub Actions: add each variable as a Repository Secret.
# ============================================================

# ────────────────────────────────────────
# DATABASES (Neon connection strings)
# ────────────────────────────────────────
# Main / fallback DB (used if a market-specific URL is not set)
DATABASE_URL=

# Manager DB (stores barcode catalog, store mappings, process timing)
DATABASE_URL_MANAGER=

# Per-market DBs — leave empty to fall back to DATABASE_URL
DATABASE_URL_ROSSI=
DATABASE_URL_ATACADAO=
DATABASE_URL_NAGUMO=
DATABASE_URL_HIGAS=
DATABASE_URL_SWIFT=
DATABASE_URL_SONDA=
DATABASE_URL_XSUPERMERCADOS=
DATABASE_URL_BARBOSA=
DATABASE_URL_CARREFOUR=
DATABASE_URL_OBA=
DATABASE_URL_EXTRA=
DATABASE_URL_PAODEACUCAR=

# Optional: shard shared/manager tables by category to separate projects.
# Leave empty to keep all shared tables in DATABASE_URL_MANAGER.
DATABASE_URL_COMMON_CATALOG=
DATABASE_URL_COMMON_INFERENCE=
DATABASE_URL_COMMON_TIMING=
DATABASE_URL_COMMON_AUDIT=
DATABASE_URL_COMMON_STORE=

# ────────────────────────────────────────
# AI PROVIDER KEYS
# ────────────────────────────────────────
HF_TOKEN=
HF_SPACE_ID=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ────────────────────────────────────────
# DB ARCHIVE (GitHub storage)
# ────────────────────────────────────────
# GitHub PAT with contents:write scope on the archive repo
DB_ARCHIVE_GITHUB_TOKEN=
# e.g. yourusername/markets-archive
DB_ARCHIVE_GITHUB_REPO=

# ────────────────────────────────────────
# SUPABASE BOOTSTRAP (optional)
# ────────────────────────────────────────
# Minimal required secret for deploy/supabase_bootstrap.py
SUPABASE_ACCESS_TOKEN=

# Optional: if token can access multiple organizations, set one explicitly
SUPABASE_ORG_ID=

# Optional defaults used by bootstrap/restore script
SUPABASE_REGION=sa-east-1
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_PREFIX=marketsdb
SUPABASE_DR_DIR=deploy/disaster_recovery
